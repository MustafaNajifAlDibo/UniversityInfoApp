<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="UniversityInfoApp.Views.UnInfoView">
    <Border StrokeShape="45">
        <VerticalStackLayout Padding="20,10" Spacing="10">
            <HorizontalStackLayout Spacing="10">
                <Image HeightRequest="50" Source="university.png"/>
                <VerticalStackLayout>
                    <Label FontSize="Large" Text="UN Full Name"/>
                    <Label TextColor="CadetBlue" FontSize="Medium" Text="www.website.com"/>
                </VerticalStackLayout>
            </HorizontalStackLayout>
        </VerticalStackLayout>
    </Border>
</ContentView>
